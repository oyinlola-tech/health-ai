# MedExplain AI environment contract
# Owner: Oluwayemi Oyinlola Michael - https://oyinlola.site

NODE_ENV=development
PORT=3000
APP_NAME="MedExplain AI"
APP_URL=http://localhost:3000
PUBLIC_APP_URL=http://localhost:3000

# MySQL / AMPPS
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=medexplain_ai
DB_CONNECTION_RETRIES=5
DB_CONNECTION_RETRY_MS=1000
SKIP_DB_STARTUP=false

# First-boot admin seeding. Replace before production.
ADMIN_EMAIL=admin@medexplain.local
ADMIN_PASSWORD=ChangeThisAdminPassword123!

# JWT and cookies. Replace every value before production.
JWT_ACCESS_SECRET=replace-with-a-strong-access-secret
JWT_REFRESH_SECRET=replace-with-a-strong-refresh-secret
JWT_ISSUER=medexplain-ai
JWT_AUDIENCE=medexplain-ai-users
JWT_ACCESS_TTL_SECONDS=900
JWT_REFRESH_TTL_SECONDS=2592000
COOKIE_SECRET=replace-with-a-strong-cookie-secret
CSRF_SECRET=replace-with-a-strong-csrf-secret

# CORS and rate limiting
CORS_ORIGINS=http://localhost:3000
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=120

# Gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash
GEMINI_FLASH_MODEL=gemini-1.5-flash
GEMINI_PRO_MODEL=gemini-1.5-pro
GEMINI_EMBEDDING_MODEL=text-embedding-004

# RAG and AI cost controls
RAG_RETRIEVAL_LIMIT=5
RAG_MAX_CONTEXT_CHARS=6000
AI_CACHE_TTL_SECONDS=3600
AI_CACHE_MAX_ITEMS=500
AI_CALL_RETRIES=2
AI_CALL_RETRY_MS=500
AI_DAILY_USER_BUDGET_NAIRA=250
AI_DAILY_GLOBAL_BUDGET_NAIRA=10000
AI_MONTHLY_SYSTEM_BUDGET_NAIRA=150000
AI_FREE_MONTHLY_BUDGET_NAIRA=1500
AI_PREMIUM_MONTHLY_BUDGET_NAIRA=37500
AI_FEATURE_REPORT_MONTHLY_BUDGET_NAIRA=90000
AI_FEATURE_CHAT_MONTHLY_BUDGET_NAIRA=37500
AI_FEATURE_DOCTOR_ASSIST_MONTHLY_BUDGET_NAIRA=30000
AI_FREE_DAILY_REQUEST_LIMIT=20
AI_PREMIUM_DAILY_REQUEST_LIMIT=250
AI_PER_MINUTE_REQUEST_LIMIT=8
AI_BURST_PER_MINUTE=5
AI_USAGE_SPIKE_ALERT_THRESHOLD=100
AI_MAX_PROMPT_CHARS=28000
AI_MAX_CONTEXT_CHARS=12000
AI_FLASH_COST_PER_1K_TOKENS_NAIRA=30
AI_PRO_COST_PER_1K_TOKENS_NAIRA=1875
AI_EMBEDDING_COST_PER_1K_TOKENS_NAIRA=15

# Email
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM="MedExplain AI <no-reply@medexplain.local>"

# Upload limits
UPLOAD_ROOT=uploads
MAX_UPLOAD_BYTES=10485760
ALLOWED_UPLOAD_MIME_TYPES=application/pdf,image/png,image/jpeg,image/webp
REPORT_EXTRACTION_CONFIDENCE_THRESHOLD=65
REPORT_PROCESSING_VERSION=report-pipeline-v1
OCR_LANGUAGE=eng

# OPay billing
PAYMENT_PROVIDER=opay
PAYMENT_PUBLIC_KEY=
PAYMENT_SECRET_KEY=
OPAY_BASE_URL=https://testapi.opaycheckout.com
OPAY_MERCHANT_ID=
OPAY_PUBLIC_KEY=
OPAY_SECRET_KEY=
OPAY_WEBHOOK_SECRET=
OPAY_COUNTRY=NG
OPAY_CURRENCY=NGN
FREE_TRIAL_DAYS=14
FREE_TRIAL_FULL_ACCESS=true
BASIC_MONTHLY_PRICE_NAIRA=5000
PREMIUM_MONTHLY_PRICE_NAIRA=12000
FREE_REPORT_ANALYSIS_LIMIT=3
FREE_AI_CHAT_LIMIT=10
PAYMENT_DATA_ENCRYPTION_SECRET=replace-with-a-strong-payment-data-encryption-secret
MESSAGE_ENCRYPTION_SECRET=replace-with-a-strong-message-encryption-secret
