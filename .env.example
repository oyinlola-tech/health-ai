# MedExplain AI environment contract
# Owner: Oluwayemi Oyinlola Michael - https://oyinlola.site

NODE_ENV=development
PORT=3000
APP_NAME="MedExplain AI"
APP_URL=http://localhost:3000
PUBLIC_APP_URL=http://localhost:3000

# PostgreSQL
DATABASE_URL=postgres://postgres:postgres@localhost:5432/medexplain_ai
DATABASE_SSL=false
SKIP_DB_STARTUP=false

# JWT and cookies. Replace every value before production.
JWT_ACCESS_SECRET=replace-with-a-strong-access-secret
JWT_REFRESH_SECRET=replace-with-a-strong-refresh-secret
JWT_ACCESS_TTL_SECONDS=900
JWT_REFRESH_TTL_SECONDS=2592000
COOKIE_SECRET=replace-with-a-strong-cookie-secret
CSRF_SECRET=replace-with-a-strong-csrf-secret

# CORS and rate limiting
CORS_ORIGINS=http://localhost:3000
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=120

# Gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash
GEMINI_FLASH_MODEL=gemini-1.5-flash
GEMINI_PRO_MODEL=gemini-1.5-pro
GEMINI_EMBEDDING_MODEL=text-embedding-004

# RAG and AI cost controls
RAG_RETRIEVAL_LIMIT=5
RAG_MAX_CONTEXT_CHARS=6000
AI_CACHE_TTL_SECONDS=3600
AI_CACHE_MAX_ITEMS=500
AI_DAILY_USER_BUDGET_CENTS=250
AI_DAILY_GLOBAL_BUDGET_CENTS=10000
AI_MONTHLY_SYSTEM_BUDGET_USD=100
AI_FREE_MONTHLY_BUDGET_USD=1
AI_PREMIUM_MONTHLY_BUDGET_USD=25
AI_FEATURE_REPORT_MONTHLY_BUDGET_USD=60
AI_FEATURE_CHAT_MONTHLY_BUDGET_USD=25
AI_FEATURE_DOCTOR_ASSIST_MONTHLY_BUDGET_USD=20
AI_FREE_DAILY_REQUEST_LIMIT=20
AI_PREMIUM_DAILY_REQUEST_LIMIT=250
AI_PER_MINUTE_REQUEST_LIMIT=8
AI_BURST_PER_MINUTE=5
AI_MAX_PROMPT_CHARS=28000
AI_MAX_CONTEXT_CHARS=12000
AI_NGN_PER_USD=0
AI_FLASH_COST_PER_1K_TOKENS_CENTS=0.02
AI_PRO_COST_PER_1K_TOKENS_CENTS=1.25
AI_EMBEDDING_COST_PER_1K_TOKENS_CENTS=0.01

# Email
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM="MedExplain AI <no-reply@medexplain.local>"

# Upload limits
UPLOAD_ROOT=uploads
MAX_UPLOAD_BYTES=10485760
ALLOWED_UPLOAD_MIME_TYPES=application/pdf,image/png,image/jpeg,image/webp
REPORT_EXTRACTION_CONFIDENCE_THRESHOLD=65
REPORT_PROCESSING_VERSION=report-pipeline-v1
OCR_LANGUAGE=eng

# OPay billing
PAYMENT_PROVIDER=opay
PAYMENT_PUBLIC_KEY=
PAYMENT_SECRET_KEY=
OPAY_BASE_URL=https://testapi.opaycheckout.com
OPAY_MERCHANT_ID=
OPAY_PUBLIC_KEY=
OPAY_SECRET_KEY=
OPAY_WEBHOOK_SECRET=
OPAY_COUNTRY=NG
OPAY_CURRENCY=NGN
PREMIUM_MONTHLY_PRICE_CENTS=500000
PREMIUM_ANNUAL_PRICE_CENTS=5000000
FREE_REPORT_ANALYSIS_LIMIT=3
FREE_AI_CHAT_LIMIT=10
MESSAGE_ENCRYPTION_SECRET=replace-with-a-strong-message-encryption-secret
