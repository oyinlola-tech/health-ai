{
  "name": "medexplain-ai",
  "version": "1.0.0",
  "private": true,
  "description": "MedExplain AI helps patients understand medical reports with secure AI-assisted explanations.",
  "author": {
    "name": "Oluwayemi Oyinlola Michael",
    "url": "https://oyinlola.site"
  },
  "license": "SEE LICENSE IN docs/decisions/LICENSE.md",
  "type": "module",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "start:full": "npm run setup && npm run dev",
    "build:css": "tailwindcss -i ./public/assets/css/input.css -o ./public/assets/css/styles.css --minify",
    "setup": "npm run migrate",
    "migrate": "node src/database/migrate.js",
    "seed": "node src/seeders/dev.seed.js",
    "normalize:public": "node scripts/normalize-public.mjs",
    "audit:integrity": "node scripts/integrity-audit.mjs",
    "ingest:medlineplus": "node scripts/ingest-medlineplus.mjs",
    "ingest:pubmed": "node scripts/ingest-pubmed.mjs",
    "kaggle:download": "node scripts/kaggle/download-datasets.js",
    "kaggle:extract": "node scripts/kaggle/extract-datasets.js",
    "kaggle:import": "node scripts/kaggle/import-datasets.js",
    "kaggle:pipeline:search": "node scripts/kaggle-pipeline/search-datasets.js",
    "kaggle:pipeline:select": "node scripts/kaggle-pipeline/select-datasets.js",
    "kaggle:pipeline:download": "node scripts/kaggle-pipeline/download-datasets.js",
    "kaggle:pipeline:validate": "node scripts/kaggle-pipeline/validate-datasets.js",
    "kaggle:pipeline:transform": "node scripts/kaggle-pipeline/transform-datasets.js",
    "kaggle:pipeline:import": "node scripts/kaggle-pipeline/import-datasets.js",
    "kaggle:pipeline": "npm run kaggle:pipeline:search && npm run kaggle:pipeline:select && npm run kaggle:pipeline:download && npm run kaggle:pipeline:validate && npm run kaggle:pipeline:transform && npm run kaggle:pipeline:import",
    "smoke:frontend": "node scripts/verify-frontend.mjs",
    "lint": "eslint . --ext .js,.mjs,.cjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:integration": "RUN_INTEGRATION_TESTS=true vitest run tests/integration"
  },
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "bcryptjs": "^3.0.3",
    "compression": "^1.8.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dotenv": "^16.6.1",
    "express": "^4.22.2",
    "express-rate-limit": "^7.5.1",
    "helmet": "^8.2.0",
    "jsonwebtoken": "^9.0.3",
    "multer": "^1.4.5-lts.2",
    "mysql2": "^3.22.4",
    "nodemailer": "^8.0.10",
    "pdf-parse": "^2.4.5",
    "socket.io": "^4.8.3",
    "swagger-ui-express": "^5.0.1",
    "tesseract.js": "^7.0.0",
    "uuid": "^11.1.1",
    "xss": "^1.0.15",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "autoprefixer": "^10.5.0",
    "eslint": "^9.39.4",
    "globals": "^15.15.0",
    "jsdom": "^29.1.1",
    "nodemon": "^3.1.14",
    "postcss": "^8.5.15",
    "prettier": "^3.8.3",
    "supertest": "^7.2.2",
    "tailwindcss": "^3.4.19",
    "vitest": "^4.1.8"
  }
}
